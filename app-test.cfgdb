{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "store":true,
  "properties": {
    "x":{
      "type":"array",
      "items": {
        "type":"object",
        "properties":{
          "name":{
            "type":"string"
          },
          "value":{
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          }
        }
      }
    }
  }
}
